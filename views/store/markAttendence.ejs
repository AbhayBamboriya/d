<%- include('../partials/head') %>
</head>

<body class="bg-gray-50 min-h-screen font-sans">
  <%- include('../partials/nav') %>
  <%- include('../partials/toast') %>
  <%- include('../partials/animation') %>

  <div class="max-w-3xl mx-auto bg-white shadow-xl rounded-2xl border border-gray-200 p-8 mt-10">
    <h1 class="text-3xl font-extrabold mb-6 text-center text-purple-700">
      Mark Attendance
    </h1>

    <!-- Attendance Filter Form -->
    <form action="/showList" method="POST" class="flex flex-col gap-6 mb-6">
      <!-- ✅ Branch Selection -->
      <div>
        <p class="font-semibold mb-2 text-gray-700">Select Branch Name:</p>
        <label class="flex items-center gap-2 mb-2">
          <input type="radio" name="className" value="CSE" <%= selectedClass === 'CSE' ? 'checked' : '' %> class="accent-purple-600" />
          CSE
        </label>
        <!-- Add more branch options here if needed -->
      </div>

      <!-- ✅ Year Selection -->
      <div class="flex-1">
        <p class="font-semibold mb-2 text-gray-700">Select Year:</p>
        <div class="flex gap-6" id="yearOptions">
          <label class="flex items-center gap-2">
            <input type="radio" name="year" value="I" <%= selectedYear === 'I' ? 'checked' : '' %> class="accent-indigo-600" /> I
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="year" value="II" <%= selectedYear === 'II' ? 'checked' : '' %> class="accent-indigo-600" /> II
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="year" value="III" <%= selectedYear === 'III' ? 'checked' : '' %> class="accent-indigo-600" /> III
          </label>
          <label class="flex items-center gap-2">
            <input type="radio" name="year" value="IV" <%= selectedYear === 'IV' ? 'checked' : '' %> class="accent-indigo-600" /> IV
          </label>
        </div>
      </div>

      <!-- ✅ Semester (Initially Hidden) -->
      <div class="flex-1 hidden" id="semesterContainer">
        <p class="font-semibold mb-2 text-gray-700">Select Semester:</p>
        <div class="flex flex-wrap gap-6" id="semesterOptions"></div>
      </div>

      <!-- ✅ Section (Initially Empty) -->
      <div class="flex-1 hidden" id="sectionContainer">
        <p class="font-semibold mb-2 text-gray-700">Select Section:</p>
        <div class="flex flex-wrap gap-6" id="sectionOptions"></div>
      </div>

      <!-- ✅ Subject Selection (You can keep as is or make dynamic later) -->
      <div>
        <label class="block font-semibold mb-1">Subject</label>
        <select id="subjectSelect" name="subject" required
                class="w-full p-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-400 mb-4">
          <option value="" disabled selected>Select subject</option>
        </select>
      </div>

      <!-- Date Auto-filled -->
      <div>
        <label class="block font-semibold mb-1">Date</label>
        <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" readonly
               class="w-full p-2 border border-gray-300 rounded-lg bg-gray-100 cursor-not-allowed mb-4">
      </div>

      <!-- Submit Button -->
      <button type="submit" class="w-full bg-blue-500 text-white py-3 rounded-xl font-bold shadow hover:bg-white hover:text-blue-500 border transition-all duration-200">
        View Students
      </button>
    </form>
   <% if (students && students.length > 0) { %>
      <form action="/submit-attendance" method="POST" class="flex flex-col gap-4">
        <input type="hidden" name="className" value="<%= selectedClass %>">
        <input type="hidden" name="sectionName" value="<%= selectedSection %>">
        <input type="hidden" name="year" value="<%= selectedYear %>">
        <input type="hidden" name="subject" value="<%= selectedSubject %>">
        <input type="hidden" name="date" value="<%= selectedDate %>">
        <input type="hidden" name="semester" id="selectedSemester" value="<%= selectedSemester || '' %>">
<!-- <input type="hidden" name="sectionName" id="selectedSection" value="<%= selectedSection || '' %>"> -->


        <div class="overflow-x-auto rounded-xl shadow-lg border border-gray-200">
          <table class="min-w-full table-auto border-collapse">
            <thead class="bg-gradient-to-r from-purple-500 to-pink-500 text-white text-lg font-bold">
              <tr>
                <th class="px-4 py-2">S.No</th>
                <th class="px-4 py-2">Name</th>
                <th class="px-4 py-2">Enrollment No</th>
                <th class="px-4 py-2">Attendance</th>
              </tr>
            </thead>
            <tbody>
              <% students.forEach((student, index) => { %>
                <tr class="hover:bg-purple-50 transition-all">
                  <td class="border px-4 py-2 text-center"><%= index + 1 %></td>
                  <td class="border px-4 py-2"><%= student.name %></td>
                  <td class="border px-4 py-2"><%= student.enrollmentNo %></td>
                  <td class="border px-4 py-2 text-center flex flex-col gap-2">
                    <label class="inline-flex items-center gap-1">
                      <input type="radio" name="attendance[<%= student.enrollmentNo %>]" value="Present" required class="accent-green-600" />
                      Present
                    </label>
                    <label class="inline-flex items-center gap-1">
                      <input type="radio" name="attendance[<%= student.enrollmentNo %>]" value="Absent" required class="accent-red-600" />
                      Absent
                    </label>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col gap-3 mt-4">
          <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded-xl shadow hover:bg-white hover:text-blue-500 border transition-all duration-200">
            Submit Attendance
          </button>

          <button type="button" onclick="selectAllPresent()" class="bg-blue-500 text-white px-6 py-2 rounded-xl shadow hover:bg-white hover:text-blue-500 border transition-all duration-200">
            Select All Present
          </button>

          <button type="button" onclick="selectAllAbsent()" class="bg-blue-500 text-white px-6 py-2 rounded-xl shadow hover:bg-white hover:text-blue-500 border transition-all duration-200">
            Select All Absent
          </button>
        </div>
      </form>

      <script>
        function selectAllPresent() {
          document.querySelectorAll('input[type="radio"][value="Present"]').forEach(radio => radio.checked = true);
        }
        function selectAllAbsent() {
          document.querySelectorAll('input[type="radio"][value="Absent"]').forEach(radio => radio.checked = true);
        }
      </script>
    <% } else if (selectedClass && selectedSection) { %>
      <p class="text-center text-gray-500 mt-6">No students found for <strong><%= selectedClass %>-<%= selectedSection %></strong>.</p>
    <% } %>

  </div>

  <script>
  // Update hidden inputs for semester
  document.getElementById('semesterOptions').addEventListener('change', (e) => {
    const semInput = document.getElementById('selectedSemester');
    if (e.target.name === 'semester') {
      semInput.value = e.target.value;
    }
  });

  // // Update hidden input for section
  // document.getElementById('sectionOptions').addEventListener('change', (e) => {
  //   const secInput = document.getElementById('selectedSection');
  //   if (e.target.name === 'sectionName') {
  //     secInput.value = e.target.value;
  //   }
  // });
</script>

  <!-- ✅ Dynamic Script -->
  <script>
    const branchRadios = document.querySelectorAll('input[name="className"]');
    const yearRadios = document.querySelectorAll('input[name="year"]');
    const semesterContainer = document.getElementById('semesterContainer');
    const semesterOptions = document.getElementById('semesterOptions');

    const sectionContainer = document.getElementById('sectionContainer');
    const sectionOptionsWrapper = document.getElementById('sectionOptions');

    async function fetchSemestersAndSections() {
      const branch = document.querySelector('input[name="className"]:checked')?.value;
      const year = document.querySelector('input[name="year"]:checked')?.value;
      if (!branch || !year) return;
      try {
        const res = await fetch(`/get-sem-sections?branchName=${branch}&year=${year}`);
        const data = await res.json();

        // Populate Semesters
        semesterOptions.innerHTML = "";
        data.forEach((item, idx) => {
          semesterOptions.innerHTML += `
            <label class="flex items-center gap-2">
              <input type="radio" name="semester" value="${item.semester}" class="accent-purple-600" ${idx === 0 ? 'checked' : ''} />
              Semester ${item.semester}
            </label>`;
        });
        semesterContainer.classList.remove('hidden');

        populateSections(data[0]?.sections || []);

        // Listen for semester change -> update sections
        document.querySelectorAll('input[name="semester"]').forEach(radio => {
          radio.addEventListener('change', e => {
            const selectedSem = e.target.value;
            const selectedData = data.find(d => d.semester === selectedSem);
            populateSections(selectedData?.sections || []);
          });
        });

      } catch (err) {
        console.error("Error fetching semesters & sections:", err);
      }
    }

    function populateSections(sections) {
      sectionOptionsWrapper.innerHTML = "";
      if (sections.length > 0) {
        sectionContainer.classList.remove('hidden');
        sections.forEach(sec => {
          sectionOptionsWrapper.innerHTML += `
            <label class="flex items-center gap-2">
              <input type="radio" name="sectionName" value="${sec}" class="accent-pink-500" />
              ${sec}
            </label>`;
        });
      } else {
        sectionContainer.classList.add('hidden');
      }
    }

    // Attach Listeners
    branchRadios.forEach(r => r.addEventListener('change', fetchSemestersAndSections));
    yearRadios.forEach(r => r.addEventListener('change', fetchSemestersAndSections));

    // Trigger once if already pre-selected
    fetchSemestersAndSections();
  </script>
<script>
const subjectSelect = document.getElementById('subjectSelect');

async function fetchSubjects(branch, year, semester, sectionName) {
  if (!branch || !year || !semester || !sectionName) return;

  try {
    const res = await fetch('/subject/get-subjects', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({ branchName: branch, year, semester, sectionName })
});

    const subjects = await res.json();

    subjectSelect.innerHTML = `<option value="" disabled selected>Select subject</option>`;
    subjects.forEach(sub => {
      subjectSelect.innerHTML += `<option value="${sub.subjectName}">${sub.subjectCode} - ${sub.subjectName}</option>`;
    });

  } catch (err) {
    console.error("Error fetching subjects:", err);
    subjectSelect.innerHTML = `<option value="" disabled selected>Error loading subjects</option>`;
  }
}

// Trigger fetch whenever section changes
sectionOptionsWrapper.addEventListener('change', () => {
  const branch = document.querySelector('input[name="className"]:checked')?.value;
  const year = document.querySelector('input[name="year"]:checked')?.value;
  const semester = document.querySelector('input[name="semester"]:checked')?.value;
  const sectionName = document.querySelector('input[name="sectionName"]:checked')?.value;

  fetchSubjects(branch, year, semester, sectionName);
});

// Optional: fetch subjects on page load if selections are pre-set
window.addEventListener('DOMContentLoaded', () => {
  const branch = document.querySelector('input[name="className"]:checked')?.value;
  const year = document.querySelector('input[name="year"]:checked')?.value;
  const semester = document.querySelector('input[name="semester"]:checked')?.value;
  const sectionName = document.querySelector('input[name="sectionName"]:checked')?.value;

  if(branch && year && semester && sectionName) {
    fetchSubjects(branch, year, semester, sectionName);
  }
});
</script>



</body>
</html>
