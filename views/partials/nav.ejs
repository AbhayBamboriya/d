<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Select Class</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

  <!-- ✅ Navbar -->
  <header class="bg-gradient-to-r from-gray-800 via-gray-700 to-gray-800 text-white shadow-lg">
    <nav class="container mx-auto flex items-center justify-between py-4 px-6">
      
      <!-- Logo / Brand -->
      <a href="/" class="text-3xl font-extrabold tracking-wide bg-gradient-to-r from-purple-400 via-pink-400 to-indigo-400 bg-clip-text text-transparent drop-shadow-lg font-cursive" style="font-family: cursive">
        <span class="ml-1">AttendEase</span>
      </a>

      <!-- Desktop Links -->
      <ul class="hidden md:flex items-center space-x-4 font-medium">
        <li>
          <a href="/" class="py-2 px-4 rounded-lg transition duration-300 <%= currentPage === 'IndexPage' ? 'bg-white text-gray-800 shadow' : 'hover:bg-white hover:text-gray-800' %>">Home</a>
        </li>

        <% if (IsLoggedIn) { %>
          <% if (user && user.userType === 'admin') { %>
            <li><a href="/add-admin" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Add Admin</a></li>
            <li><a href="/upload" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Upload Student Data</a></li>
            <!-- ✅ Only admin can access Manage Subjects -->
            <li><a href="/add-subjects" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Manage Subjects</a></li>
          <% } %>

          <% if (user && user.userType === 'teacher') { %>
            <li><a href="/showStudents" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Show Students</a></li>
            <li><a href="/markAttendance" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Mark Attendance</a></li>
            <li><a href="/report" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">View Attendance</a></li>
            <li><a href="/view" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Generate Report </a></li>
          <% } %>

          <% if (user && user.userType === 'student') { %>
            <li><a href="/student-dashboard" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Student Dashboard</a></li>
          <% } %>

          <li>
            <form action="/logout" method="POST">
              <button type="submit" class="py-2 px-4 rounded-lg transition duration-300 hover:bg-white hover:text-gray-800">Logout</button>
            </form>
          </li>
        <% } %>
      </ul>

      <!-- Mobile Hamburger -->
      <div class="md:hidden">
        <button id="menu-btn" class="focus:outline-none">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-gray-800">
      <ul class="flex flex-col px-6 py-4 space-y-2 text-white">
        <li><a href="/" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Home</a></li>
        <% if (IsLoggedIn) { %>
          <% if (user && user.userType === 'admin') { %>
            <li><a href="/add-admin" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Add Admin</a></li>
            <li><a href="/upload" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Upload Student Data</a></li>
            <li><a href="/add-subjects" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Manage Subjects</a></li>
          <% } %>

          <% if (user && user.userType === 'teacher') { %>
            <li><a href="/showStudents" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Show Students</a></li>
            <li><a href="/markAttendance" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Mark Attendance</a></li>
          <% } %>

          <% if (user && user.userType === 'student') { %>
            <li><a href="/student-dashboard" class="block py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Student Dashboard</a></li>
          <% } %>

          <li>
            <form action="/logout" method="POST">
              <button type="submit" class="w-full text-left py-2 px-4 rounded-lg hover:bg-white hover:text-gray-800 transition">Logout</button>
            </form>
          </li>
        <% } %>
      </ul>
    </div>
  </header>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn.addEventListener('click', () => menu.classList.toggle('hidden'));
  </script>
</body>
</html>
