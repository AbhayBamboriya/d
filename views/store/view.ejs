<main class="container">
  <!-- Page Header -->
  <h2 class="page-title">Attendance Report</h2>

  <!-- Filter Card -->
  <div class="card">
    <h3 class="card-title">🔍 Filter Students by Attendance</h3>

    <form id="attendanceForm" class="form-grid">
      <!-- Branch -->
      <div class="form-group">
        <label for="branchName">Branch</label>
        <select name="branchName" id="branchName" required>
          <option value="">-- Select Branch --</option>
          <option value="CSE">CSE</option>
          <option value="ECE">ECE</option>
          <option value="ME">ME</option>
        </select>
      </div>

      <!-- Year -->
      <div class="form-group">
        <label for="year">Year</label>
        <select name="year" id="year" required>
          <option value="">-- Select Year --</option>
          <option value="I">I</option>
          <option value="II">II</option>
          <option value="III">III</option>
          <option value="IV">IV</option>
        </select>
      </div>

      <!-- Semester (Dynamic) -->
      <div class="form-group">
        <label for="semester">Semester</label>
        <select name="semester" id="semester" required>
          <option value="">-- Select Semester --</option>
        </select>
      </div>

      <!-- Section (Dynamic) -->
      <div class="form-group">
        <label for="sectionName">Section</label>
        <select name="sectionName" id="sectionName" required>
          <option value="">-- Select Section --</option>
        </select>
      </div>

      <!-- Apply & Reset -->
      <div class="form-group">
        <button type="submit" class="btn btn-primary">Apply</button>
        <button type="reset" class="btn btn-secondary">Reset</button>
      </div>

      <!-- Download Button -->
      <div class="form-group">
        <button type="button" id="downloadBtn" class="btn btn-success">⬇ Download</button>
      </div>
    </form>
  </div>
</main>

<script>
  const branchEl = document.getElementById("branchName");
  const yearEl = document.getElementById("year");
  const semesterEl = document.getElementById("semester");
  const sectionEl = document.getElementById("sectionName");

  let semesterData = []; // store fetched data to avoid multiple fetch calls

  // Fetch semesters & sections when branch or year changes
  async function fetchSemestersAndSections() {
    const branch = branchEl.value;
    const year = yearEl.value;

    if (!branch || !year) {
      semesterEl.innerHTML = '<option value="">-- Select Semester --</option>';
      sectionEl.innerHTML = '<option value="">-- Select Section --</option>';
      semesterData = [];
      return;
    }

    try {
      const response = await fetch(`/get-sem-sections?branchName=${branch}&year=${year}`);
      semesterData = await response.json();

      // Populate Semester Dropdown
      semesterEl.innerHTML = '<option value="">-- Select Semester --</option>';
      semesterData.forEach(item => {
        const opt = document.createElement("option");
        opt.value = item.semester;
        opt.textContent = `Semester ${item.semester}`;
        semesterEl.appendChild(opt);
      });

      sectionEl.innerHTML = '<option value="">-- Select Section --</option>';
    } catch (err) {
      console.error("Error fetching semesters/sections:", err);
    }
  }

  // When semester changes, populate sections from already fetched data
  semesterEl.addEventListener("change", () => {
    const selectedSem = semesterEl.value;
    const selectedObj = semesterData.find(item => item.semester === selectedSem);

    sectionEl.innerHTML = '<option value="">-- Select Section --</option>';
    if (selectedObj) {
      selectedObj.sections.forEach(sec => {
        const opt = document.createElement("option");
        opt.value = sec;
        opt.textContent = sec;
        sectionEl.appendChild(opt);
      });
    }
  });

  branchEl.addEventListener("change", fetchSemestersAndSections);
  yearEl.addEventListener("change", fetchSemestersAndSections);

  // Form Submit
  document.getElementById("attendanceForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const branch = branchEl.value;
    const year = yearEl.value;
    const semester = semesterEl.value;
    const section = sectionEl.value;

    if (!branch || !year || !semester || !section) {
      alert("⚠ Please select all fields.");
      return;
    }

    window.location.href = `/attendance/${branch}/${year}/${semester}/${section}`;
  });

  document.getElementById("downloadBtn").addEventListener("click", function () {
    const branch = branchEl.value;
    const year = yearEl.value;
    const semester = semesterEl.value;
    const section = sectionEl.value;

    if (!branch || !year || !semester || !section) {
      alert("⚠ Please select all fields to download report.");
      return;
    }

    window.location.href = `/attendance/${branch}/${year}/${semester}/${section}/download`;
  });
</script>
